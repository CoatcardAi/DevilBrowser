{
  "manifest_version": 3,
  "name": "AiMagic",
  "version": "1.0.0",
  "description": "Agentic AI solver for context-aware responses with API key rotation.",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "64": "icon64.png",
    "128": "icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icon.png", "icon128.png", "icon64.png", "icon48.png", "icon32.png", "icon16.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "identity",
    "cookies",
    "contextMenus",
    "tabs",
    "clipboardWrite",
    "clipboardRead",
    "alarms"
  ],
  "oauth2": {
    "client_id": "YOUR_CLIENT_ID.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.email"
    ]
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open AiMagic Options",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "64": "icon64.png",
      "128": "icon128.png"
    }
  },
  "commands": {
    "activate_solver": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Toggle AiMagic Solver Button Visibility"
    },
    "ghost_solve": {
      "suggested_key": {
        "default": "Alt+G"
      },
      "description": "Trigger Silent Ghost Solver"
    },
    "reload_extension": {
      "suggested_key": {
        "default": "Alt+R"
      },
      "description": "Hard Reload Extension"
    },
    "trigger_autotype": {
      "suggested_key": {
        "default": "Alt+T"
      },
      "description": "Start AutoTyper"
    },
    "open_chat": {
      "description": "Toggle AiMagic Chat"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["content.css"],
      "js": ["content.js"]
    }
  ]
}
